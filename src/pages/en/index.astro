---
import Layout from "../../layouts/Layout.astro";
import SpotlightBackground from "../../components/react/SpotlightBackground";
import GlowCard from "../../components/react/GlowCard";
import ContributionGraph from "../../components/react/ContributionGraph";
---

<Layout title="Zichao Zhou — AI Engineer" lang="en">
  <SpotlightBackground client:load />

  <section class="spotlight relative z-10 flex min-h-[85vh] items-center justify-center px-6">
    <div class="mx-auto max-w-3xl text-center">
      <div class="animate-fade-in-up">
        <p class="mb-4 text-sm font-medium tracking-[0.3em] text-accent uppercase">AI Engineer</p>
      </div>

      <h1 class="animate-fade-in-up delay-100 font-bold tracking-tight">
        <span class="text-gradient text-5xl md:text-7xl">Zichao Zhou</span>
      </h1>

      <p class="animate-fade-in-up delay-200 mt-3 text-base text-text-muted md:text-lg">
        周 子超
      </p>

      <p class="animate-fade-in-up delay-300 mx-auto mt-8 max-w-xl text-base leading-relaxed text-text-muted md:text-lg">
        AI Safety × Psychology × Digital Humans.<br />
        I turn ideas into <strong class="text-text">production-grade commercial AI systems</strong><br />
        and keep them running.
      </p>

      <div class="animate-fade-in-up delay-400 mt-10 flex flex-wrap items-center justify-center gap-3 text-xs text-text-dim">
        <span class="rounded-full border border-border px-3 py-1">Python</span>
        <span class="rounded-full border border-border px-3 py-1">LLM Orchestration</span>
        <span class="rounded-full border border-border px-3 py-1">Edge AI</span>
        <span class="rounded-full border border-border px-3 py-1">GCP / AWS</span>
        <span class="rounded-full border border-border px-3 py-1">Multi-Agent</span>
        <span class="rounded-full border border-border px-3 py-1">AI × Psychology M.A.</span>
      </div>
    </div>
  </section>

  <section class="relative z-10 mx-auto max-w-5xl px-6 pb-24">
    <h2 class="animate-fade-in-up mb-12 text-center text-sm font-medium tracking-[0.3em] text-text-dim uppercase">Projects</h2>

    <div class="grid gap-8 md:grid-cols-2">
      <GlowCard client:visible accentColor="#f59e0b" href="/en/guardian">
        <div class="mb-4 flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-guardian/10 text-guardian">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <span class="text-xs font-medium tracking-widest text-guardian uppercase">Anti-Fraud</span>
        </div>
        <h3 class="mb-3 text-xl font-bold text-white">GenAI Guardian</h3>
        <p class="mb-4 text-sm leading-relaxed text-text-muted">
          Fully offline edge AI system for detecting telecom fraud. Analyzes conversational context to identify psychological manipulation patterns in real-time.
        </p>
        <div class="flex flex-wrap gap-2 text-xs text-text-dim">
          <span class="rounded border border-border px-2 py-0.5">Edge AI</span>
          <span class="rounded border border-border px-2 py-0.5">NLP</span>
          <span class="rounded border border-border px-2 py-0.5">Criminology</span>
          <span class="rounded border border-border px-2 py-0.5">Fully Offline</span>
        </div>
      </GlowCard>

      <GlowCard client:visible accentColor="#8b5cf6" href="/en/clawlive">
        <div class="mb-4 flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-clawlive/10 text-clawlive">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a9 9 0 0 1 9 9 9 9 0 0 1-9 9"/><circle cx="12" cy="12" r="3"/><path d="M3 12a9 9 0 0 1 3.36-7"/><path d="M3 12a9 9 0 0 0 3.36 7"/></svg>
          </div>
          <span class="text-xs font-medium tracking-widest text-clawlive uppercase">Digital Being</span>
        </div>
        <h3 class="mb-3 text-xl font-bold text-white">ClawLive</h3>
        <p class="mb-4 text-sm leading-relaxed text-text-muted">
          AI agent-based digital being commerce platform. Personality-driven digital beings deliver 24/7 live commerce with authentic character consistency.
        </p>
        <div class="flex flex-wrap gap-2 text-xs text-text-dim">
          <span class="rounded border border-border px-2 py-0.5">Multi-Agent</span>
          <span class="rounded border border-border px-2 py-0.5">Live Commerce</span>
          <span class="rounded border border-border px-2 py-0.5">Personality AI</span>
          <span class="rounded border border-border px-2 py-0.5">140+ Languages</span>
        </div>
      </GlowCard>
    </div>

    <div class="mt-8">
      <GlowCard client:visible accentColor="#00d4aa">
        <h3 class="mb-4 text-lg font-bold text-white">Production Systems</h3>
        <div class="grid gap-6 md:grid-cols-2">
          <div>
            <h4 class="mb-1 text-sm font-semibold text-accent">AI Smart Lighting System for North American IoT</h4>
            <p class="text-sm text-text-muted">For a US-based IoT manufacturer. 200K+ requests/year. Full lifecycle ownership from design to billing.</p>
          </div>
          <div>
            <h4 class="mb-1 text-sm font-semibold text-accent">Unstructured Data Extraction System</h4>
            <p class="text-sm text-text-muted">Payslip & tax form extraction. 20K+ monthly requests in stable production.</p>
          </div>
        </div>
      </GlowCard>
    </div>
  </section>

  <section class="relative z-10 border-t border-border/50 py-16">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2 class="mb-8 text-sm font-medium tracking-[0.3em] text-text-dim uppercase">Activity & Contact</h2>

      <div class="mb-8 overflow-hidden rounded-lg border border-border bg-bg-card p-6">
        <ContributionGraph client:load username="zxvchaos" year={2025} />
        <p class="mt-3 text-xs text-text-dim">GitHub — Most repositories are private for commercial & IP reasons</p>
      </div>

      <div class="flex flex-col items-center gap-4">
        <a
          href="mailto:zxvchaos@gmail.com"
          class="inline-flex items-center gap-2 rounded-lg border border-accent/30 bg-accent/5 px-6 py-3 text-sm font-medium text-accent transition-all hover:bg-accent/10 hover:border-accent/50"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          zxvchaos@gmail.com
        </a>
        <p class="text-xs text-text-dim">
          AI × Psychology M.A. ・ 10+ years in Japan ・ Trilingual (JP/CN/EN)
        </p>
      </div>
    </div>
  </section>
</Layout>
