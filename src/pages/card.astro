---
import "../styles/global.css";
import SpotlightBackground from "../components/react/SpotlightBackground";
---

<!DOCTYPE html>
<html lang="ja" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="周 子超 (Shicho Shu) — AI Engineer. AIセーフティ × 心理学 × デジタルヒューマン。" />
  <title>周 子超 | Shicho Shu — AI Engineer</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen bg-bg text-text antialiased">

  <!-- Animated particle background (same as main site) -->
  <SpotlightBackground client:load />

  <!-- Spotlight radial glow -->
  <div class="spotlight fixed inset-0 -z-10 pointer-events-none"></div>

  <main class="relative z-10 flex min-h-screen flex-col items-center justify-center px-6 py-16">
    <div class="w-full max-w-sm">

      <!-- Identity -->
      <div class="animate-fade-in-up mb-10 text-center">
        <div class="avatar-ring mx-auto mb-5 flex h-20 w-20 items-center justify-center rounded-full border border-accent/30 bg-accent/5 text-3xl font-bold text-accent">
          周
        </div>
        <h1 class="text-2xl font-bold text-white tracking-tight">周 子超</h1>
        <p class="mt-1 text-sm text-text-muted">Shicho Shu</p>
        <p class="mt-3 text-xs font-medium tracking-[0.2em] text-accent uppercase">AI Engineer</p>
        <p class="mt-4 text-sm text-text-muted leading-relaxed">
          AIセーフティ × 心理学 × デジタルヒューマン
        </p>
      </div>

      <!-- Links -->
      <div class="flex flex-col gap-3">

        <a href="/" class="animate-fade-in-up delay-100 card-link group">
          <div class="link-icon bg-accent/10 text-accent group-hover:bg-accent/20">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
          </div>
          <div class="min-w-0">
            <p class="text-sm font-medium text-white">ポートフォリオ</p>
            <p class="truncate text-xs text-text-dim">zxvchaos.github.io</p>
          </div>
          <svg class="link-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>

        <a href="mailto:zxvchaos@gmail.com" class="animate-fade-in-up delay-200 card-link group">
          <div class="link-icon bg-accent/10 text-accent group-hover:bg-accent/20">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <div class="min-w-0">
            <p class="text-sm font-medium text-white">メール</p>
            <p class="truncate text-xs text-text-dim">zxvchaos@gmail.com</p>
          </div>
          <svg class="link-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>

        <a href="https://github.com/zxvchaos" target="_blank" rel="noopener" class="animate-fade-in-up delay-300 card-link group">
          <div class="link-icon bg-accent/10 text-accent group-hover:bg-accent/20">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65S8.93 17.38 9 18v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          </div>
          <div class="min-w-0">
            <p class="text-sm font-medium text-white">GitHub</p>
            <p class="truncate text-xs text-text-dim">zxvchaos</p>
          </div>
          <svg class="link-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>

        <a href="/guardian" class="animate-fade-in-up delay-400 card-link group">
          <div class="link-icon bg-guardian/10 text-guardian group-hover:bg-guardian/20">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div class="min-w-0">
            <p class="text-sm font-medium text-white">GenAI Guardian</p>
            <p class="truncate text-xs text-text-dim">エッジ AI 特殊詐欺検知</p>
          </div>
          <svg class="link-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>

        <a href="/clawlive" class="animate-fade-in-up delay-500 card-link group">
          <div class="link-icon bg-clawlive/10 text-clawlive group-hover:bg-clawlive/20">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a9 9 0 0 1 9 9 9 9 0 0 1-9 9"/><circle cx="12" cy="12" r="3"/><path d="M3 12a9 9 0 0 1 3.36-7"/><path d="M3 12a9 9 0 0 0 3.36 7"/></svg>
          </div>
          <div class="min-w-0">
            <p class="text-sm font-medium text-white">ClawLive</p>
            <p class="truncate text-xs text-text-dim">デジタルビーイング商業プラットフォーム</p>
          </div>
          <svg class="link-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>

      </div>

      <!-- Footer -->
      <p class="animate-fade-in-up delay-600 mt-12 text-center text-xs text-text-dim leading-relaxed">
        AI × 心理学修士 ・ 在日 10 年以上<br />日中英トリリンガル
      </p>

    </div>
  </main>

</body>
</html>

<style>
  /* Avatar glow ring */
  .avatar-ring {
    box-shadow: 0 0 30px rgba(0, 212, 170, 0.15), 0 0 60px rgba(0, 212, 170, 0.05);
  }

  .card-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    transition: all 0.2s;
    text-decoration: none;
  }
  .card-link:hover {
    background: var(--color-bg-card-hover);
    border-color: var(--color-accent);
    box-shadow: 0 0 24px rgba(0, 212, 170, 0.08);
  }
  .link-icon {
    display: flex;
    height: 2.5rem;
    width: 2.5rem;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    transition: background-color 0.2s;
  }
  .link-arrow {
    margin-left: auto;
    flex-shrink: 0;
    color: var(--color-text-dim);
    transition: transform 0.2s;
  }
  .card-link:hover .link-arrow {
    transform: translateX(2px);
  }
</style>
