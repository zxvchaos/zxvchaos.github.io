---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = "AI Engineer — AI Safety × Psychology × Digital Humans", lang = "ja" } = Astro.props;

// Extract page path without language prefix for language switcher
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
let pagePath = pathname;
if (pathname.startsWith('/en')) pagePath = pathname.slice(3) || '/';
else if (pathname.startsWith('/zh')) pagePath = pathname.slice(3) || '/';
// Ensure trailing slash for GitHub Pages compatibility
const trail = (p: string) => p === '/' ? '/' : `${p}/`;
const jpPath = trail(pagePath);
const enPath = trail(pagePath === '/' ? '/en' : `/en${pagePath}`);
const zhPath = trail(pagePath === '/' ? '/zh' : `/zh${pagePath}`);

// Active page detection for nav highlighting
const isHome = pagePath === '/';
const isGuardian = pagePath === '/guardian';
const isClawLive = pagePath === '/clawlive';
---

<!DOCTYPE html>
<html lang={lang} class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen bg-bg text-text antialiased">
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-border/50 bg-bg/80 backdrop-blur-xl">
    <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
      <a href={lang === "en" ? "/en/" : lang === "zh" ? "/zh/" : "/"} class={`group flex items-center gap-2 text-lg font-semibold tracking-tight hover:text-accent transition-colors ${isHome ? "text-accent" : ""}`} title="Home">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={`group-hover:text-accent transition-colors ${isHome ? "text-accent" : "text-text-dim"}`}><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <span>Z. Zhou</span>
      </a>
      <div class="flex items-center gap-6 text-sm text-text-muted">
        <a href={lang === "en" ? "/en/guardian/" : lang === "zh" ? "/zh/guardian/" : "/guardian/"} class={`hover:text-accent transition-colors ${isGuardian ? "text-accent font-medium" : ""}`}>Guardian</a>
        <a href={lang === "en" ? "/en/clawlive/" : lang === "zh" ? "/zh/clawlive/" : "/clawlive/"} class={`hover:text-accent transition-colors ${isClawLive ? "text-accent font-medium" : ""}`}>ClawLive</a>
        <span class="h-4 w-px bg-border"></span>
        <a href={jpPath} class={`hover:text-accent transition-colors ${lang === "ja" ? "text-accent" : ""}`}>JP</a>
        <a href={enPath} class={`hover:text-accent transition-colors ${lang === "en" ? "text-accent" : ""}`}>EN</a>
        <a href={zhPath} class={`hover:text-accent transition-colors ${lang === "zh" ? "text-accent" : ""}`}>ZH</a>
      </div>
    </div>
  </nav>

  <main class="pt-16">
    <slot />
  </main>

  <footer class="border-t border-border/50 py-8">
    <div class="mx-auto max-w-5xl px-6 text-center text-sm text-text-dim">
      <p>&copy; 2026 Zichao Zhou. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>
